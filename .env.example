# Server
PORT=3000
APP_URL=http://localhost:3000

# AI provider:
# - mock: local deterministic fallback, no key required
# - deepseek: DeepSeek OpenAI-compatible chat API
# - openai-compatible: any OpenAI-compatible provider such as Qwen-compatible gateways
AI_PROVIDER=mock

# DeepSeek example:
# AI_PROVIDER=deepseek
# DEEPSEEK_API_KEY=sk-xxxx
# AI_BASE_URL=https://api.deepseek.com/chat/completions
# AI_MODEL=deepseek-chat

# Generic OpenAI-compatible example:
# AI_PROVIDER=openai-compatible
# AI_API_KEY=sk-xxxx
# AI_BASE_URL=https://your-provider.example.com/v1/chat/completions
# AI_MODEL=your-model-name

# Optional reverse geocoding for browser location.
# Keep this key on the server only; the frontend calls /api/geocode/reverse.
# If omitted, the app uses a no-key fallback service and then coordinates as backup.
# AMAP_WEB_SERVICE_KEY=your-amap-web-service-key
